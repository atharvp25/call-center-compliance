# ── CALL Analytics API — Environment Variables ──────────────────────────
# Copy this file to .env and fill in your actual keys

# Sarvam AI — Speech-to-Text (Hindi & Tamil)
SARVAM_API_KEY=your_sarvam_api_key_here

# Google Gemini — LLM Analysis
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model (change if needed)
GEMINI_MODEL=gemini-2.5-flash

# Gemini timeout in milliseconds
GEMINI_TIMEOUT_MS=120000

# API Authentication — the key judges will use to call your API
CALL_API_KEY=hcl-guvi-hackathon-2026

# ChromaDB persistence directory (defaults to system temp)
# CHROMA_PERSIST_DIR=./chroma_data

# Celery broker URL (Redis)
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Server port
PORT=8000
